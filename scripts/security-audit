#!/usr/bin/env bash
# Quick security audit: surface anything anomalous from logs, auth, network.
# Run as root (or via sudo).

set -u

if [[ $EUID -ne 0 ]]; then
    exec sudo -E "$0" "$@"
fi

bold() { printf '\n\033[1;36m== %s ==\033[0m\n' "$*"; }
warn() { printf '\033[1;33m%s\033[0m\n' "$*"; }

read_log() {
    local f=$1
    [[ -f $f ]] || return 0
    case $f in
        *.zst) zstdcat "$f" 2>/dev/null ;;
        *.gz)  zcat "$f" 2>/dev/null ;;
        *)     cat "$f" ;;
    esac
}

bold "Boot history (looking for unclean shutdowns)"
last -x reboot shutdown | head -20

bold "Failed login attempts (lastb)"
if command -v lastb >/dev/null; then
    lastb -a 2>/dev/null | head -20 || echo "(no btmp / no failures)"
else
    echo "(lastb not available)"
fi

bold "Recent logins (last)"
last -a | head -15

bold "Auth failures / denials in secure logs"
for f in /var/log/secure /var/log/secure.1.zst /var/log/secure.2.zst; do
    [[ -f $f ]] || continue
    read_log "$f" \
        | grep -iE 'fail|invalid|illegal|break-in|unauthorized|denied|authentication failure|bad password|preauth' \
        | grep -viE 'pam_unix.*session (opened|closed)' \
        | tail -40
done

bold "Sudo invocations (last 30)"
for f in /var/log/secure /var/log/secure.1.zst; do
    [[ -f $f ]] || continue
    read_log "$f" | grep -iE 'sudo.*COMMAND=' | tail -30
done

bold "SSH session activity"
for f in /var/log/secure /var/log/secure.1.zst; do
    [[ -f $f ]] || continue
    read_log "$f" | grep -iE 'sshd.*(accepted|opened|closed|disconnect|connection from)' | tail -20
done

bold "Listening TCP/UDP sockets"
ss -tulnp 2>/dev/null

bold "Established external connections (non-loopback, non-LAN)"
ss -tnp state established 2>/dev/null \
    | awk 'NR>1 {print $4, $5, $6}' \
    | grep -vE '127\.|::1|192\.168\.|10\.|172\.(1[6-9]|2[0-9]|3[01])\.|fe80:' \
    | head -30

bold "World-listening services (0.0.0.0 / ::)"
ss -tlnp 2>/dev/null | grep -E '0\.0\.0\.0:|\[::\]:' || echo "(none)"

bold "Setuid/setgid files modified in last 7 days"
find / -xdev \( -perm -4000 -o -perm -2000 \) -mtime -7 -type f 2>/dev/null

bold "Files in /tmp /var/tmp /dev/shm modified in last 24h"
find /tmp /var/tmp /dev/shm -xdev -mtime -1 -type f 2>/dev/null | head -30

bold "Cron / at jobs"
ls -la /var/spool/cron/ /var/spool/cron/crontabs/ 2>/dev/null
ls -la /etc/cron.d/ /etc/cron.hourly/ /etc/cron.daily/ 2>/dev/null | tail -30

bold "Recent root-owned processes"
ps -eo user,pid,etime,cmd --sort=etime | awk '$1=="root"' | head -20

bold "Kernel / hardware error indicators"
dmesg 2>/dev/null | grep -iE 'panic|oops|segfault|hardware error|mce|pstore|tainted' | tail -20

bold "Pstore (crash data persisted across reboot)"
ls -la /sys/fs/pstore/ /var/lib/systemd/pstore/ 2>/dev/null || echo "(empty)"

bold "Done"
